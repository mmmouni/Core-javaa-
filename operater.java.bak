import java.util.Scanner;
class operater
{
	public static void main(String [] args)
	{
		Scanner s = new Scanner(System.in);
		System.out.println("Enter a symbal...");
		char symbal = s.next().charAt(0);
		switch(symbal)
		{
			case "+"   : System.out.println("Enter your option Addition...");
			             break;
			case "-"   : System.out.println("Substraction of two numbers...");
			             break;
            case  "*"  : System.out.println("multiplication of two numbers...");
			             break;  
			case  "/"  : System.out.println("divistion of two numbers...");
			             break;
            case "%"   : System.out.println("moduler divistion of two numbers...");
			             break;
            default    : System.out.println("Enter valid Symbal");
		}
	}
}


            
		
			             

