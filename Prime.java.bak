import java.util.Scanner;
class Prime
{
	public static void main(String[] args)
	{
		Scanner s = new Scanner(System.in);
		System.out.println("eneter a number");
		int number = s.nextInt();
		for(int i= 2 ; i < number; i++)
		{
			int fact = 0;
			for(int j=1; j < i ; j++)
			{
				if(number % j == 0)
				{
					fact++;
					break;
				}
			}
		if(fact==0)
			{
			System.out.println("prime");
			}
		}
	}
}





